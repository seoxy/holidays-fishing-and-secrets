[sub_resource type="GDScript" id="GDScript_qf8ov"]
resource_name = "ButtonPisciclopedie"
script/source = "extends Button

@onready var control_pisciclopedie: Control = $\"../../ControlPisciclopedie\"


# Si on presse le bouton P, cela affiche la pisciclopedie.
func _on_pressed() -> void:
	control_pisciclopedie.show()
	
	# Met en pause tout le jeu.
	get_tree().paused = true
"

