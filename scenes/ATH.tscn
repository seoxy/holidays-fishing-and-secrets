[sub_resource type="GDScript" id="GDScript_2gnp0"]
resource_name = "PanelTemps"
script/source = "extends Panel

@onready var label_temps : Label = $LabelTemps

func _process(_delta: float) -> void:
	_actualiser_label()

# Permet de voir l'heure en temps réel.
func _actualiser_label() :
	label_temps.text = str(Gheure.heures) + \" : \" + str(Gheure.minutes)
"

[sub_resource type="GDScript" id="GDScript_twrn0"]
resource_name = "PanelMeteo"
script/source = "extends Panel

@onready var label_meteo: Label = $LabelMeteo

func _process(delta: float) -> void:
	_actualiser_label()

func _actualiser_label() :
	label_meteo.text = Gheure.meteo
"

