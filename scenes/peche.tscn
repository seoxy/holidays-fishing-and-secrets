[sub_resource type="GDScript" id="GDScript_isj87"]
resource_name = "fish"
script/source = "# S'occupe uniquement de bouger le poisson, rien d'autre.
extends AnimatedSprite2D

var move_distance := 50
var move_time := 0.6

var init_position :Vector2 = Vector2(-3.0, 101.0)

func _on_timer_timeout() -> void:
	var direction := randi_range(-1, 1)
	var target_position := position
	
	target_position.y += direction * move_distance
	
	if direction != 0 :
		var tween := create_tween()
		tween.tween_property(self, \"position\", clamp(target_position, Vector2(-3, -90), Vector2(-3, 90)), move_time)
"

