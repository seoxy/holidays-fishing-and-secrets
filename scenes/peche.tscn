[sub_resource type="GDScript" id="GDScript_y5cj3"]
resource_name = "ControlFinpartie"
script/source = "extends Control


func _on_node_peche_end_party(result: String, first_catch: bool) -> void:
	if result == \"réussite\" and first_catch == false :
		$LabelFinPartie.text = \"Succès\"
	elif result == \"réussite\" and first_catch == true :
		$LabelFinPartie.text = \"Première prise !\"
	else :
		$LabelFinPartie.text = \"Echec...\"
"

