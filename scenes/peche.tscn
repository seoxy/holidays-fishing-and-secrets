[sub_resource type="GDScript" id="GDScript_h5hh0"]
resource_name = "CanvasPeche"
script/source = "# S'occupe uniquement d'afficher ou de cacher les divers éléments.
extends CanvasLayer

func _ready() -> void:
	$NodePeche.hide()
	$ControlFinPartie.hide()
	$ContainerMenu.show()

# Pour entrer dans le jeu de pêche.
func _on_button_pecher_pressed() -> void:
	$ContainerMenu.hide()
	$NodePeche.show()

# Pour afficher \"succès\" ou \"échec\" à la fin de la partie.
func _on_node_peche_end_party(_result: String, _first_catch: bool) -> void:
	$NodePeche.hide()
	$ControlFinPartie.show()

# Pour revenir au menu principal.
func _on_button_fin_partie_pressed() -> void:
	# Permet de pouvoir repêcher.
	Gsignals.player_is_fishing = false
	queue_free()
"

[sub_resource type="GDScript" id="GDScript_t71sy"]
resource_name = "Principal"
script/source = "extends Node2D

#region Raccourcis de noeuds.
@onready var timer: Timer = %Timer
@onready var progress_bar: ProgressBar = %ProgressBar
#endregion

#region Variables.
var is_on_bar := false
var fishing := false

var fish_to_catch :Dictionary

signal begining_party
signal end_party(result:String, first_catch:bool)
#endregion

####################################################################################################
func _process(_delta: float) -> void:
	if self.is_visible_in_tree() and fishing == false :
		_start_of_the_game()
	if fishing :
		_end_of_the_game()

############################### Fonctions de la partie en cours. ###################################
# Sert à déterminer si on joue ou pas, afin de lancer le chrono qui fait bouger le poisson
# et permet d'augmenter le score.
func _start_of_the_game() :
	begining_party.emit()
	fishing = true
	progress_bar.value = 50
	_set_fishing()
	timer.start()

# Choisit aléatoirement un poisson à pêcher dans la liste.
func _set_fishing() :
	fish_to_catch = Gfishes.all_fishes.pick_random()


# Pour vérifier si le poisson est sur la barre ou pas.
func _on_area_2d_body_entered(_body: Node2D) -> void:
	is_on_bar = true

# Pour vérifier si le poisson est sur la barre ou pas.
func _on_area_2d_body_exited(_body: Node2D) -> void:
	is_on_bar = false

func _on_timer_timeout() -> void:
	if is_on_bar :
		$%ProgressBar.value += 5
	else :
		$%ProgressBar.value -= 5
############################### Fonctions de fin de partie. ########################################

# Ajoute le poisson à l'inventaire du joueur ou pas selon réussite.
func _end_of_the_game() :
	# Si le joueur atteint 100, le poisson choisit aléatoirement est ajouté à son inventaire.
	if $ProgressBar.value == 100 :
		# Vérifie si le joueur n'a pas déjà le poisson dans son inventaire.
		if Ginventaire.fishes_catched.find(fish_to_catch) == -1 :
			Ginventaire.fishes_catched.append(fish_to_catch)
			print(Ginventaire.fishes_catched)
			end_party.emit(\"réussite\", true)
		else : end_party.emit(\"réussite\", false)
		fishing = false
		
	if $ProgressBar.value == 0 :
		fishing = false
		end_party.emit(\"échec\", false)
"

